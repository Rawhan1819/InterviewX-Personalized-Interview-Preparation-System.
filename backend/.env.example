# InterviewX Backend — Environment Configuration
# Copy this file to .env and fill in your values.

# --- Database ---
# Default is SQLite (no config needed). Uncomment below for MySQL:
# DATABASE_URL=mysql+pymysql://root:YOUR_PASSWORD@localhost:3306/interviewx

# --- Security ---
SECRET_KEY=change-this-in-production-to-a-long-random-string

# --- HuggingFace ---
HUGGINGFACE_TOKEN=hf_YOUR_TOKEN_HERE
